<!DOCTYPE html>
<html>

<head>

    <title>Login</title>

</head>

<body>

<h2>RentApp Pro</h2>

<form method="POST" action="/login">

    <input
        type="text"
        name="username"
        placeholder="Username"
        required>

    <br><br>

    <input
        type="password"
        name="password"
        placeholder="Password"
        required>

    <br><br>

    <button>

        Login

    </button>

</form>

<p style="color:red">

<%= error %>

</p>

</body>

</html>