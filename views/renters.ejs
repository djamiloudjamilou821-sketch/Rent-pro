<%- include("partials/header") %>
<%- include("partials/sidebar") %>

<div class="main">
    <div class="content">

        <div class="renters-header">
            <h2>👥 Renters</h2>
            <a href="/renters/add" class="btn btn-primary btn-add" title="Add Renter">
                +
            </a>
        </div>

        <!-- Search and Filter Form -->
        <form method="GET" action="/renters" class="row g-3 mb-4">
            <div class="col-md-6">
                <input
                    type="text"
                    class="form-control"
                    name="search"
                    placeholder="Search by name, phone or address..."
                    value="<%= search || '' %>">
            </div>
            <div class="col-md-3">
                <select
                    name="filter"
                    class="form-select">
                    <option value="all" <%= filter=="all" ? "selected" : "" %>>
                        All
                    </option>
                    <option value="paid" <%= filter=="paid" ? "selected" : "" %>>
                        Paid
                    </option>
                    <option value="late" <%= filter=="late" ? "selected" : "" %>>
                        Late
                    </option>
                </select>
            </div>
            <div class="col-md-3 d-grid">
                <button type="submit" class="btn btn-primary">
                    Search
                </button>
            </div>
        </form>

        <div class="card">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="mb-0">
                        Total Renters:
                        <span class="status-badge status-paid">
                            <%= total %>
                        </span>
                    </h5>
                </div>
                
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>Name</th>
                                <th>Phone</th>
                                <th>Address</th>
                                <th class="text-center">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if(renters.length===0){ %>
                                <tr>
                                    <td colspan="5" class="text-center py-4">
                                        No renters found.
                                    </td>
                                </tr>
                            <% } %>
                            <% renters.forEach(r=>{ %>
                                <tr>
                                    
                                    <td>
                                        <a href="/renters/<%= r.id %>" class="fw-bold text-decoration-none">
                                            <%= r.name %>
                                        </a>
                                    </td>
                                    <td>
                                        <%= r.phone || "-" %>
                                    </td>
                                    <td>
                                        <span class="text-truncate d-inline-block" style="max-width: 150px;">
                                            <%= r.address || "-" %>
                                        </span>
                                    </td>
                                    <td class="text-center">
                                        <a
                                            href="/payments/<%= r.id %>"
                                            class="btn btn-sm btn-primary px-3">
                                            Pay
                                        </a>
                                    </td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>


    </div>
</div>

<%- include("partials/footer") %>
