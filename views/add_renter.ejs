<!DOCTYPE html>

<html>

<head>

    <title>Add Renter</title>

    <link
    href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.7/dist/css/bootstrap.min.css"
    rel="stylesheet">

</head>

<body class="bg-light">

<div class="container mt-5">

<div class="card shadow">

<div class="card-body">

<h2>Add New Renter</h2>

<form
method="POST"
action="/renters/add">

<div class="mb-3">

<label class="form-label">

Name

</label>

<input
type="text"
name="name"
class="form-control"
required>

</div>


<div class="mb-3">

<label class="form-label">

Phone

</label>

<input
type="text"
name="phone"
class="form-control">

</div>


<div class="mb-3">

<label class="form-label">

Address

</label>

<input
type="text"
name="address"
class="form-control">

</div>


<div class="d-flex gap-2">

<button
type="submit"
class="btn btn-primary">

Save Renter

</button>

<a
href="/renters"
class="btn btn-secondary">

Cancel

</a>

</div>

</form>

</div>

</div>

</div>

</body>

</html>